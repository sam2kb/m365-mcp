# Account name configured with: npm run auth -- add <name> <tenant-id> <client-id>
M365_ACCOUNT=work

# IANA timezone used for Microsoft Graph calendar operations
M365_TIMEZONE=America/New_York

# Optional safety mode: request read-only OAuth scopes, hide mutating tools,
# and reject direct calls to them.
# M365_MCP_READ_ONLY=true

# Optional auth storage override (default: ~/.m365-mcp/auth)
# Use an absolute path; variable expansion is not supported by every .env loader.
# M365_MCP_AUTH_DIR=/absolute/path/to/m365-mcp-auth

# This project does not load .env files automatically; source it or pass these variables through your MCP client.
