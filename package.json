{
  "name": "@sam2kb/m365-mcp",
  "version": "1.0.2",
  "description": "Production-grade Microsoft 365 MCP server — email, calendar, contacts, OneDrive, Teams, tasks, and users via delegated OAuth",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    ".env.example",
    "LICENSE",
    "README.md",
    "SKILL.md"
  ],
  "bin": {
    "m365-mcp": "dist/index.js",
    "m365-mcp-auth": "dist/auth-cli.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc",
    "prepack": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "auth": "tsx src/auth-cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "microsoft365",
    "outlook",
    "teams",
    "onedrive",
    "graph-api"
  ],
  "author": "Alex Kay <info@wittyfinch.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sam2kb/m365-mcp.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.7"
  },
  "engines": {
    "node": ">=18"
  }
}
